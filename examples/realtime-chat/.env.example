# Realtime Chat Demo env
#
# Recommended (browser-safe): point the demo at the relay and DO NOT set a public API key.
# Start the relay from repo root:
#   PORT=2859 TARGET_URL="https://stardust.ticos.cn/realtime" AUTH_TOKEN="..." pnpm relay
NEXT_PUBLIC_TICOS_API_URL=ws://localhost:2859
#
# Direct connection (NOT recommended in browsers):
# NEXT_PUBLIC_TICOS_API_URL=wss://stardust.ticos.cn/realtime
# NEXT_PUBLIC_TICOS_API_KEY=your_api_key_here
# NEXT_PUBLIC_DANGEROUSLY_ALLOW_API_KEY_IN_BROWSER=true
